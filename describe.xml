<?xml version="1.0" encoding="UTF-8"?>
<!--
  describe.xml — adapter descriptor for the example/template adapter.

  When you instantiate this template, rename:
    - the AdapterKind  key="example_adapter"   -> your adapter kind (snake_case),
      matching ADAPTER_KIND in your *Adapter.java and adapter_kind in adapter.yaml.
    - the CredentialKind / ResourceKind keys, identifiers, groups, and attributes
      to describe your target system.

  Conventions (match the production adapters):
    - nameKey integers index resources.properties (display strings).
    - The adapter instance is a type="7" ResourceKind whose key == the AdapterKind
      key; it carries credentialKind + the connection ResourceIdentifiers.
    - Monitored resources are type="1"; isProperty="true" for string properties,
      isProperty="false" (+ dataType="float") for numeric metrics.
    - A World resource is the traversal entry point referenced by the
      TraversalSpecKind ResourcePath.
-->
<AdapterKind xmlns="http://schemas.vmware.com/vcops/schema"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             key="example_adapter"
             nameKey="1"
             version="1"
             xsi:schemaLocation="http://schemas.vmware.com/vcops/schema describeSchema.xsd">

	<CredentialKinds>
		<CredentialKind key="example_credentials" nameKey="2">
			<CredentialField key="username" nameKey="3" type="string" required="true" dispOrder="1"/>
			<CredentialField key="password" nameKey="4" type="string" required="true" password="true" dispOrder="2"/>
		</CredentialKind>
	</CredentialKinds>

	<ResourceKinds>

		<!-- ================================================================ -->
		<!-- Adapter Instance (type=7): connection configuration              -->
		<!-- ================================================================ -->
		<ResourceKind key="example_adapter" nameKey="5" type="7"
		              credentialKind="example_credentials"
		              monitoringInterval="5">
			<ResourceIdentifier key="host" nameKey="6" type="string"
			                    required="true" dispOrder="1"/>
			<ResourceIdentifier key="port" nameKey="7" type="string"
			                    required="false" dispOrder="2" default="443"/>
			<ResourceIdentifier key="allowInsecure" nameKey="8" type="string"
			                    required="false" dispOrder="3" default="true"/>
		</ResourceKind>

		<!-- ================================================================ -->
		<!-- World: traversal entry point                                     -->
		<!-- ================================================================ -->
		<ResourceKind key="World" nameKey="10" type="1">
			<ResourceIdentifier key="world_id" nameKey="11" type="string" required="true" dispOrder="1"/>
		</ResourceKind>

		<!-- ================================================================ -->
		<!-- ExampleResource: the one monitored resource kind in this skeleton -->
		<!-- ================================================================ -->
		<ResourceKind key="ExampleResource" nameKey="20" type="1">
			<ResourceIdentifier key="id" nameKey="21" type="string" required="true" dispOrder="1"/>

			<ResourceGroup key="Status" nameKey="22" instanced="false">
				<ResourceAttribute key="value" nameKey="23" dataType="float"
				                   isProperty="false" defaultMonitored="true"/>
			</ResourceGroup>

			<ResourceGroup key="Configuration" nameKey="24" instanced="false">
				<ResourceAttribute key="name" nameKey="25" dataType="string" isProperty="true"/>
			</ResourceGroup>
		</ResourceKind>

	</ResourceKinds>

	<TraversalSpecKinds>
		<TraversalSpecKind name="Example Infrastructure"
		                   nameKey="30"
		                   rootAdapterKind="example_adapter"
		                   rootResourceKind="example_adapter"
		                   filterType="GENERIC_RELATION"
		                   usedFor="ALL">
			<!-- World > ExampleResource -->
			<ResourcePath path="example_adapter::example_adapter||example_adapter::World::child||example_adapter::ExampleResource::child"/>
		</TraversalSpecKind>
	</TraversalSpecKinds>

	<LicenseConfig enabled="false"/>

</AdapterKind>
