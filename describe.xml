<?xml version="1.0" encoding="UTF-8"?>
<AdapterKind xmlns="http://schemas.vmware.com/vcops/schema"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             key="hello_world"
             nameKey="1"
             version="1"
             xsi:schemaLocation="http://schemas.vmware.com/vcops/schema describeSchema.xsd">

	<CredentialKinds>
		<CredentialKind key="hello_world_credentials" nameKey="2">
			<CredentialField key="username" nameKey="3" type="string" required="true" dispOrder="1"/>
			<CredentialField key="password" nameKey="4" type="string" required="true" password="true" dispOrder="2"/>
		</CredentialKind>
	</CredentialKinds>

	<ResourceKinds>
		<!-- Adapter instance (type=7): the per-connection configuration object -->
		<ResourceKind key="hello_world" nameKey="5" type="7"
		              credentialKind="hello_world_credentials"
		              monitoringInterval="5">
			<ResourceIdentifier key="greetingName" nameKey="6" type="string"
			                    required="false" dispOrder="1"/>
		</ResourceKind>

		<!-- HelloResource (type=1): the discovered resource that we collect metrics from -->
		<ResourceKind key="HelloResource" nameKey="7" type="1">
			<ResourceIdentifier key="id" nameKey="8" type="string" required="true" dispOrder="1"/>
			<ResourceGroup key="Metrics" nameKey="9" instanced="false">
				<ResourceAttribute key="tickCount" nameKey="10" dataType="float"
				                   isProperty="false" defaultMonitored="true"/>
			</ResourceGroup>
			<ResourceGroup key="Properties" nameKey="11" instanced="false">
				<ResourceAttribute key="greeting" nameKey="12" dataType="string"
				                   isProperty="true" defaultMonitored="true"/>
			</ResourceGroup>
		</ResourceKind>
	</ResourceKinds>

	<LicenseConfig enabled="false"/>

</AdapterKind>
